# EasyMall 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ===== 应用配置 =====
# Spring Boot 激活的 profile（dev 或 prod）
SPRING_PROFILES_ACTIVE=dev

# 应用端口
APP_PORT=8080

# ===== MySQL 配置 =====
MYSQL_PASSWORD=your_mysql_root_password

# MySQL 端口映射（仅 Docker 使用）
MYSQL_PORT=3306

# ===== Redis 配置 =====
# Redis 连接密码（生产环境必须设置）
SPRING_DATA_REDIS_PASSWORD=your_redis_password

# Redis 端口映射（仅 Docker 使用）
REDIS_PORT=6379

# ===== 生产环境专用 =====
# 以下变量仅在使用 prod profile 时需要设置
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/easymall?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=UTC
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your_db_password
# SPRING_DATA_REDIS_HOST=redis
# SPRING_DATA_REDIS_PORT=6379
# JWT_SECRET=your_jwt_secret_key_at_least_256_bits_long
# FILE_UPLOAD_BASE_PATH=/data/easymall/uploads
# FILE_UPLOAD_BASE_URL=https://your-domain.com/uploads

# ===== 日志级别（可选） =====
# LOG_LEVEL=info
# LOG_LEVEL_SECURITY=warn
