# EasyMall 环境变量配置示例
# 后端：cp .env.example easymall-backend/.env 并填入实际值

# ===== 应用配置 =====
SPRING_PROFILES_ACTIVE=prod
APP_PORT=8080

# ===== MySQL 配置 =====
MYSQL_PASSWORD=your_mysql_root_password
MYSQL_PORT=3306

# ===== Redis 配置 =====
REDIS_PASSWORD=
REDIS_PORT=6379

# ===== RabbitMQ 配置 =====
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ===== 安全配置 =====
JWT_SECRET=your_jwt_secret_key_at_least_256_bits_long

# ===== 文件上传 =====
FILE_UPLOAD_BASE_URL=http://localhost:8080/uploads
